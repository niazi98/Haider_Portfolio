# SMTP Configuration for Nodemailer (Gmail)
# Get an App Password from Google Account Settings > Security > 2-Step Verification > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# MongoDB Configuration (Optional - for database storage)
MONGODB_URI=mongodb://localhost:27017/haider-portfolio

# Admin Email for Notifications
ADMIN_EMAIL=niaziumar98@gmail.com
